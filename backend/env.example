# OpenTelemetry Tracing Configuration
JAEGER_HOST=localhost
JAEGER_PORT=4317
ENABLE_CONSOLE_EXPORTER=true

# Backend Configuration
# DEBUG: only the app.* loggers. AAuth loggers: AAUTH_LOG_LEVEL and/or AAUTH_DEBUG; a2a/httpx: *_LOG_LEVEL below.
DEBUG=true
LOG_LEVEL=info

# AAuth logging: set AAUTH_LOG_LEVEL=DEBUG (or INFO/WARNING/...) for aauth + aauth_signing loggers.
# If AAUTH_LOG_LEVEL is unset, AAUTH_DEBUG=1 turns those loggers to DEBUG (same flag name as aauth demos).
# AAUTH_LOG_LEVEL=INFO
# AAUTH_DEBUG=0
# A2A_LOG_LEVEL=WARNING
# HTTPX_LOG_LEVEL=WARNING

# A2A Agent Configuration
SUPPLY_CHAIN_AGENT_URL=http://supply-chain-agent.localhost:3000

# AAuth Configuration
# Signature scheme: "hwk" (pseudonymous) or "jwks_uri" (identified agent)
# Default: hwk (maintains backward compatibility)
AAUTH_SIGNATURE_SCHEME=hwk
# Agent identifier for JWKS scheme (HTTPS URL)
# Used in Signature-Key header: scheme=jwks_uri id="<BACKEND_AGENT_URL>" kid="..."
BACKEND_AGENT_URL=http://backend.localhost:8000


# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aauth-test

# Keycloak AAuth Configuration (for autonomous authorization)
# AAuth issuer URL - used to fetch metadata and request auth tokens
# If not set, derived from KEYCLOAK_URL and KEYCLOAK_REALM
KEYCLOAK_AAUTH_ISSUER_URL=http://localhost:8080/realms/aauth-test
# Optional explicit token endpoint override. If unset, read from issuer metadata.
# KEYCLOAK_AAUTH_TOKEN_ENDPOINT=http://localhost:8080/realms/aauth-test/protocol/aauth/token
# Optional explicit interaction endpoint override. If unset, read from issuer metadata.
# KEYCLOAK_AAUTH_INTERACTION_ENDPOINT=http://localhost:8080/realms/aauth-test/protocol/aauth/interact
# Auth token cache TTL in seconds (default: 3600)
AAUTH_AUTH_TOKEN_CACHE_TTL=3600


# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
CORS_ALLOW_ALL=true
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3050,http://127.0.0.1:3000,http://127.0.0.1:3050,http://localhost:5173,http://127.0.0.1:5173
